# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node
node_modules/
web/.next/
web/out/
*.tsbuildinfo

# Env / secrets
.env
.env.local

# Storage artifacts (generated at runtime)
storage/processed/energyplus/
storage/processed/reports/
storage/processed/vector/
storage/raw/weather/*.epw

# CCTV demo clips: licensed stock (Artlist) annotated with YOLO offline; live in
# MinIO object storage, not committed (large + license). Regenerate with
# scripts/annotate_cctv_yolo.py then scripts/upload_media.py.
data/cctv_samples/clips/*.webm
web/public/cctv/*.webm

# 3D viewer fallback (large; regenerated by build_3d_assets_ifc.py). The
# committed XKT + metadata + manifest are what the viewer actually loads.
web/public/assets/buildings/*/geometry/geometry.json
web/public/assets/buildings/*/glb/

# Electrical KG: large regenerable board timeseries (Parquet) + DuckDB scratch.
# The committed CSV summaries + graph + reports capture the results; regenerate
# the Parquet with: python scripts/build_electrical_kg.py --phase timeseries
data/electrical_distribution/board_estimated_timeseries.parquet
data/electrical_distribution/board_load_category_timeseries.parquet
data/electrical_distribution/_duck_tmp/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Caddy data volume (if run locally)
caddy_data/
caddy_config/

# Heavy BIM reference dataset (Nordic Office/Housing source CAD binaries).
# The runnable demo only needs data/greenflow_archetype.idf (kept below).
# These multi-GB .ifc/.rvt/.pla files exceed GitHub's 100 MB/file limit and
# are not required to run GreenFlow. See README "Mở rộng (P1/P2)" for how to
# obtain them when implementing the IFC extractor.
data/ARCH/
data/HVAC/
data/STRUCTURAL/
data/enriched_IFC/
*.ifc
*.rvt
*.pla

# Heavy EnergyPlus 'gold' dataset (multi-GB DuckDB + partitioned Parquet). These
# exceed GitHub's 100 MB/file limit and are regenerable; the committed electrical
# CSV/graph outputs capture the results the app actually serves. Kept local only.
data/final/
*.duckdb

