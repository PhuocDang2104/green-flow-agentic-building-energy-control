# --- App ---
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# --- Database ---
DATABASE_URL=postgresql+psycopg://greenflow:greenflow@localhost:5432/greenflow

# --- LLM (LLM_PROVIDER=openai|anthropic|none) ---
# "none" = fully deterministic rule-based fallback, demo works without any API key.
LLM_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Storage ---
STORAGE_DIR=./storage

# --- EnergyPlus (optional; synthetic baseline used when missing) ---
ENERGYPLUS_BIN=
WEATHER_EPW=./storage/raw/weather/hanoi.epw
IDF_PATH=./data/greenflow_archetype.idf

# --- Policy guardrails ---
ENABLE_AUTO_ACTIONS=true
MAX_SETPOINT_DELTA_C=1.5
MIN_OCCUPANCY_CONFIDENCE=0.8

# --- Demo ---
DEFAULT_BUILDING_ID=b0000000-0000-0000-0000-000000000001
REPLAY_SPEED_SECONDS=10

# --- Web ---
NEXT_PUBLIC_API_BASE=/api
NEXT_PUBLIC_WS_BASE=/ws

# --- Deploy (Caddy). Set DOMAIN to a real domain on VNPT cloud for auto-HTTPS ---
DOMAIN=:80
